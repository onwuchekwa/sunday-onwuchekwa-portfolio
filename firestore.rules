rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Public site content: anyone can read, only the admin can write.
    match /siteSettings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /about/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /publications/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /news/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cv/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Anything else: admin only (default deny for the public).
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
